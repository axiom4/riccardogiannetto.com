{
  "name": "rg-web-new",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "postbuild": "node scripts/generate-sri.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "generate:api": "openapi-generator-cli generate  -p supportsES6=true,withInterfaces=true,useSingleRequestParameter=true -i http://127.0.0.1:8000/openapi -g typescript-angular -o src/app/modules/core/api/v1",
    "lint": "eslint ."
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/prismjs": "^1.26.6",
    "dompurify": "^3.4.8",
    "leaflet": "^1.9.4",
    "marked": "^18.0.5",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@openapitools/openapi-generator-cli": "^2.38.0",
    "@types/jasmine": "~6.0.0",
    "eslint": "^10.4.1",
    "jasmine-core": "~6.3.0",
    "node-html-parser": "^7.1.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.60.1"
  }
}
